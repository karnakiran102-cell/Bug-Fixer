# Multi-Agent SDLC System - Environment Configuration
# Copy this file to .env and fill in your actual API keys
# NEVER commit this file with real keys to version control!

# ============================================================================
# OPENAI CONFIGURATION (Default)
# ============================================================================
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-actual-key-here
# Optional: Override default model
# OPENAI_MODEL_NAME=gpt-4

# ============================================================================
# ANTHROPIC (CLAUDE) CONFIGURATION
# ============================================================================
# Get your API key from: https://console.anthropic.com/
# Uncomment to use instead of OpenAI
# ANTHROPIC_API_KEY=sk-ant-your-actual-key-here

# ============================================================================
# GOOGLE GEMINI CONFIGURATION
# ============================================================================
# Get your API key from: https://ai.google.dev/
# Uncomment to use instead of OpenAI
# GOOGLE_API_KEY=your-actual-key-here

# ============================================================================
# OPTIONAL CONFIGURATION
# ============================================================================
# Python logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Timeout for LLM API calls (seconds)
LLM_TIMEOUT=120

# Maximum retries for API calls
MAX_RETRIES=3

# Enable verbose output
VERBOSE_LOGGING=false

# ============================================================================
# DEVELOPMENT SETTINGS
# ============================================================================
# Set to true to use mock responses instead of real API calls
USE_MOCK_LLM=false

# Cache API responses (requires caching setup)
ENABLE_CACHE=false
CACHE_DIR=./llm_cache
